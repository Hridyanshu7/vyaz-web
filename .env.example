# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Apify (for scraping Amazon + Goodreads book data)
VITE_APIFY_TOKEN=your-apify-api-token

# Google Books API (optional fallback, free 1000 req/day with key)
VITE_GOOGLE_BOOKS_API_KEY=your-google-books-api-key

# PostHog (analytics — traffic/funnel/drop-off tracking)
VITE_POSTHOG_KEY=your-posthog-project-api-key
VITE_POSTHOG_HOST=https://us.i.posthog.com
